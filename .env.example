# 超级定价系统环境配置示例
# 复制此文件为 .env 并根据需要修改配置
# 配置模块映射见 src/settings/（base/data/trading/api/performance/gui）

# =============================================================================
# 基础配置
# =============================================================================

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# 项目环境
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# 数据配置
# =============================================================================

# 数据缓存配置
DATA_CACHE_SIZE=100
CACHE_TTL=3600
DEFAULT_LOOKBACK_DAYS=365

# 数据源配置
YFINANCE_TIMEOUT=30
DATA_REFRESH_INTERVAL=300

# =============================================================================
# 交易配置
# =============================================================================

# 默认交易参数
DEFAULT_INITIAL_CAPITAL=10000.0
DEFAULT_COMMISSION=0.001
DEFAULT_SLIPPAGE=0.001

# 风险管理
MAX_POSITION_SIZE=0.1
STOP_LOSS_THRESHOLD=0.05
TAKE_PROFIT_THRESHOLD=0.15

# =============================================================================
# API配置
# =============================================================================

# 服务器配置
API_HOST=127.0.0.1
API_PORT=8100
API_RELOAD=true
API_TIMEOUT=30
BACKEND_PUBLIC_URL=http://127.0.0.1:8100
FRONTEND_ORIGIN=http://127.0.0.1:3100

# 前端配置
FRONTEND_URL=http://localhost:3100
FRONTEND_PORT=3100

# CORS配置（src/settings/api.py 解析）
# - 留空时按 ENVIRONMENT 推导：production 仅放行 FRONTEND_URL；其它环境额外放行 localhost。
# - 显式设置时完全覆盖默认值，支持 JSON 数组或逗号分隔。
# - 严禁 "*" 与 allow_credentials=True 组合（代码会拦截）。
# CORS_ORIGINS=["https://app.example.com","https://admin.example.com"]
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# 增量放行：在默认或显式白名单基础上追加来源（生产逐步加白时方便）
# CORS_EXTRA_ORIGINS=https://staging.example.com

# =============================================================================
# 性能配置
# =============================================================================

# 并发配置
MAX_WORKERS=4
ASYNC_POOL_SIZE=10

# 缓存配置
CACHE_MAX_MEMORY_ITEMS=1000
CACHE_CLEANUP_INTERVAL=3600

# =============================================================================
# 监控配置
# =============================================================================

# 健康检查
HEALTH_CHECK_TIMEOUT=10
BACKEND_WAIT_TIMEOUT=30

# 系统监控阈值
CPU_WARNING_THRESHOLD=80.0
MEMORY_WARNING_THRESHOLD=85.0
DISK_WARNING_THRESHOLD=90.0

# 性能监控
PERFORMANCE_LOG_THRESHOLD=1.0
SLOW_QUERY_THRESHOLD=5.0

# =============================================================================
# 安全配置
# =============================================================================

# API安全
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
MAX_REQUEST_SIZE=10485760
AUTH_SECRET="dev-only-change-me"

# 数据安全
ENABLE_DATA_ENCRYPTION=false
ENCRYPTION_KEY=""

# 审计日志
ENABLE_AUDIT_LOG=true
AUDIT_LOG_RETENTION_DAYS=90

# =============================================================================
# 开发配置
# =============================================================================

# 测试配置
TEST_DATA_PATH=tests/data
MOCK_EXTERNAL_APIS=false

# 调试配置
ENABLE_PROFILING=false
PROFILE_OUTPUT_DIR=profiles

# 开发工具
AUTO_RELOAD=true
ENABLE_DEBUG_TOOLBAR=false

# =============================================================================
# 生产配置
# =============================================================================

# 生产环境特定配置（当ENVIRONMENT=production时生效）
PROD_LOG_LEVEL=WARNING
PROD_API_HOST=0.0.0.0
PROD_DEBUG=false
PROD_AUTO_RELOAD=false

# 数据库配置（如果使用数据库）
DATABASE_URL=""
DATABASE_POOL_SIZE=10
DATABASE_TIMEOUT=30

# 外部服务配置
REDIS_URL=""
ELASTICSEARCH_URL=""
CELERY_BROKER_URL=""
CELERY_RESULT_BACKEND=""

# 本地 Docker infra stack 默认值（scripts/start_infra_stack.sh 会按这些参数自动生成运行时连接）
TIMESCALE_DB=quant_research
TIMESCALE_USER=quant
TIMESCALE_PASSWORD=quant_dev_password
TIMESCALE_PORT=5432
REDIS_PORT=6379
# 如需固定到 .env，可直接取消注释以下推荐值
# DATABASE_URL="postgresql://quant:quant_dev_password@127.0.0.1:5432/quant_research"
# REDIS_URL="redis://127.0.0.1:6379/0"
# CELERY_BROKER_URL="redis://127.0.0.1:6379/0"
# CELERY_RESULT_BACKEND="redis://127.0.0.1:6379/0"
CELERY_LOGLEVEL=info
CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_POOL=solo

# OAuth 提供商（填入后可在基础设施页一键从环境同步）
GITHUB_OAUTH_ENABLED=true
GITHUB_OAUTH_CLIENT_ID=""
GITHUB_OAUTH_CLIENT_SECRET=""
GITHUB_OAUTH_REDIRECT_URI=""
GITHUB_OAUTH_FRONTEND_ORIGIN=""
GITHUB_OAUTH_SCOPES="read:user user:email"
GITHUB_OAUTH_DEFAULT_SCOPES="quant:read quant:write"
GITHUB_OAUTH_DEFAULT_ROLE="researcher"
GITHUB_OAUTH_AUTO_CREATE_USER=true

GOOGLE_OAUTH_ENABLED=true
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI=""
GOOGLE_OAUTH_FRONTEND_ORIGIN=""
GOOGLE_OAUTH_SCOPES="openid email profile"
GOOGLE_OAUTH_DEFAULT_SCOPES="quant:read quant:write"
GOOGLE_OAUTH_DEFAULT_ROLE="researcher"
GOOGLE_OAUTH_AUTO_CREATE_USER=true

# =============================================================================
# 通知配置
# =============================================================================

# 邮件通知
SMTP_HOST=""
SMTP_PORT=587
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_USE_TLS=true

# 钉钉/企业微信通知
DINGTALK_WEBHOOK=""
WECHAT_WEBHOOK=""

# =============================================================================
# 备份配置
# =============================================================================

# 自动备份
ENABLE_AUTO_BACKUP=false
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=backups
